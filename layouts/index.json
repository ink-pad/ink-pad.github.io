{{- $pages := slice -}}
{{- range site.RegularPages -}}
  {{- $pages = $pages | append (dict "title" .Title "url" .Permalink "summary" (.Summary | plainify | truncate 200) "tags" (delimit .Params.tags ", ") "section" .Section "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $pages | jsonify -}}
